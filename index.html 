<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Chrome Magic Console</title>
    <style>
        body {
            background-color: #050505;
            color: #00ff41; /* Verde Neón Hacker */
            font-family: 'Courier New', Courier, monospace;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
        }
        .console {
            border: 2px solid #00ff41;
            padding: 20px;
            box-shadow: 0 0 20px #00ff41;
            width: 80%;
            max-width: 600px;
            background: rgba(0, 255, 65, 0.05);
        }
        h1 { text-shadow: 0 0 10px #00ff41; font-size: 1.5rem; }
        .status { color: #ff00ff; } /* Rosa Cyber */
        .btn {
            background: transparent;
            border: 1px solid #00ff41;
            color: #00ff41;
            padding: 10px 20px;
            cursor: pointer;
            margin-top: 20px;
        }
        .btn:hover { background: #00ff41; color: #000; }
    </style>
</head>
<body>
    <div class="console">
        <h1>[ CHROME MAGIC GOOD V2 ]</h1>
        <p>> Estatus del Sistema: <span class="status">OPERACIONAL</span></p>
        <p>> Motor: FFmpeg Stream-Copy</p>
        <p>> Segmentos: 60 Segundos</p>
        <hr>
        <p id="log">> Esperando entrada de video...</p>
        <button class="btn" onclick="alert('Sistema Automatizado Activo')">REINICIAR MOTOR</button>
    </div>
</body>
</html>
